{
  "$schema": "../../../schemas/dataform/form-definition.schema.json",
  "summarizer": {
    "phrases": [
      {
        "visibility": [
          {
            "field": "value",
            "comparison": "defined"
          }
        ],
        "tokens": [
          {
            "type": "literal",
            "text": "has "
          },
          {
            "type": "value",
            "field": "value"
          },
          {
            "type": "literal",
            "text": " health points"
          }
        ]
      }
    ]
  },
  "title": "Health",
  "description": "Defines the health pool for an entity, measured in health points (1 point = half a heart). Typical values: cow (10), zombie (20), iron golem (100), wither (600).",
  "fields": [
    {
      "id": "value",
      "title": "Value",
      "description": "Starting health for this entity in health points (1 point = half a heart).",
      "dataType": "int",
      "experienceType": "slider",
      "minValue": 0,
      "suggestedMaxValue": 120,
      "defaultValue": 20,
      "alternates": [
        {
          "id": "value",
          "dataType": "object",
          "subForm": {
            "fields": [
              {
                "id": "range_min",
                "dataType": "int"
              },
              {
                "id": "range_max",
                "dataType": "int"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "max",
      "title": "Max",
      "description": "Maximum health this entity can have. Can be higher than the starting value to allow healing beyond initial health.",
      "dataType": "int",
      "experienceType": "slider",
      "minValue": 0,
      "suggestedMaxValue": 120,
      "defaultValue": 20
    }
  ]
}
